    },
    {
      "scenario_id": "AA08-SMOKE-EXPERIMENTS",
      "description": "Verify experiment catalog and hypothesis fields",
      "command": "rch exec -- env CARGO_INCREMENTAL=0 CARGO_TARGET_DIR=/tmp/rch-codex-aa081 cargo test --test transport_frontier_benchmark_contract experiment -- --nocapture"
    },
    {
      "scenario_id": "AA08-SMOKE-SIM-NETWORK",
