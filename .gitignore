artifacts/
!artifacts/
artifacts/*
!artifacts/runtime_workload_corpus_v*.json

# UBS (Ultimate Bug Scanner) output
ubs_*.txt
ubs-output*.txt

# Generic scratch output
output.txt
*.diff

# Cargo expand output
/expanded.rs

