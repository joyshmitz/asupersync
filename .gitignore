*.log
*.pdb

# Coverage
*.profraw
*.profdata
lcov.info
tarpaulin-report.html

# Benchmarks
criterion/

# Documentation build
/doc/

# Environment
.env
.env.local

# bv (beads viewer) local config and caches
.bv/

# Beads local artifacts in sub-projects (databases, locks, temp files)
**/.beads/*.db
**/.beads/*.db-shm
**/.beads/*.db-wal
**/.beads/daemon.*
**/.beads/last-touched
**/.beads/.local_version

# Agent artifact reports (keep local, don't commit)
/exploration_report.md
/final_summary.txt

# Local perf/profiling artifacts (keep local)
/perf.data*
/perf_*.data*
/perf.*.data
/callgrind.out.*
/flamegraph*.svg

# Lean build artifacts (keep local)
**/.lake/

# Local scratch / build outputs
/tmp/
.tmp/
**/a.out

# Compiler crash reports
rustc-ice-*.txt

# Local scratch DBs
storage.sqlite3
storage.sqlite3-*

# bv graph output
--graph-format.svg

# Beads ephemeral files (locks, migration hints, backups)
**/.beads/.bv.lock
**/.beads/.migration-hint-ts
**/.beads/*.bak_*
**/.beads/.br_history/issues.*.jsonl

# bd obligation patches
.bd-*.patch

# Ephemeral files (agent-generated, build artifacts, test detritus)
ci-artifacts/
proptest-regressions/
test_meminfo

# Agent session ephemeral files
SESSION_TODO.md
SESSION_REPORT.md
SESSION_*.md
/session_report.md
verify_*.sh
newfile.txt
repro_*.rs

# FastEmbed model caches
.fastembed_cache/

# Agent coordination config
.agent-mail.yaml

# Claude local settings and worktrees
.claude/settings.local.json
.claude/worktrees/

